@startuml
left to right direction
skinparam packageStyle rectangle

actor "Usuario" as U
actor "Admin" as A

package "Extras & Events" {
  ' Usos del Usuario '
  usecase "Ver los eventos (antiguos y próximos)" as UC1
  usecase "Filtrar eventos por categoría y/o artista" as UC2
  usecase "Reservar entrada para los eventos" as UC3

  ' Usos del Administrador '
  usecase "Añadir eventos" as UC4
  usecase "Eliminar eventos" as UC5
  usecase "Editar eventos" as UC6
}

U --> UC1
U --> UC2
U --> UC3

A --> UC4
A --> UC5
A --> UC6

@enduml